# Required — Postgres connection string from Neon / Vercel Postgres / Supabase
# Use the POOLED connection URL for serverless. Example (Neon):
#   postgres://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Required — Resend API key for transactional email (https://resend.com)
RESEND_API_KEY=

# Required — verified sender email registered with Resend (e.g. noreply@yourdomain.com)
RESEND_FROM=

# Required — operator email that receives new enrollment notifications
NOTIFY_EMAIL=shirinakhavi@yahoo.com

# Optional — set to bootstrap the admin login on first /api/auth/login request.
# When set (>= 8 chars), the user with email NOTIFY_EMAIL will be upserted as admin
# with this password if no password is already set. Safe to leave unset for launch.
ADMIN_BOOTSTRAP_PASSWORD=
